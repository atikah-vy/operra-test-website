# ─────────────────────────────────────────────────────────────
# Operra STL OS — environment variables
# Copy to `.env` and fill in the values you need. Unfilled
# integration keys leave the adapter in "not configured" mode
# (adapters return a clean skipped result instead of failing).
# ─────────────────────────────────────────────────────────────

# Core
ENVIRONMENT=development
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Web app (Next.js)
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Database — Neon (async driver is required)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-something.us-east-1.aws.neon.tech/operra

# Redis / ARQ
REDIS_URL=redis://localhost:6379/0

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWKS_URL=https://clerk.your-app.com/.well-known/jwks.json
CLERK_ISSUER=https://clerk.your-app.com
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# Public lead capture — marketing form attaches leads to this org by slug
PUBLIC_LEAD_ORG_SLUG=default

# Attio (CRM)
ATTIO_API_KEY=
ATTIO_WEBHOOK_SECRET=
ATTIO_WORKSPACE_ID=

# Apollo (lead enrichment)
APOLLO_API_KEY=

# Metricool (social)
METRICOOL_API_TOKEN=
METRICOOL_USER_ID=

# Bukku (Malaysian accounting)
BUKKU_API_KEY=
BUKKU_COMPANY_ID=

# Cal.com (bookings)
CALCOM_API_KEY=
CALCOM_WEBHOOK_SECRET=

# Meta (Facebook / Instagram)
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_IG_BUSINESS_ID=
